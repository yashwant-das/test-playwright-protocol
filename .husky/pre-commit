#!/bin/sh

echo "🛡️  Running Pre-Commit Checks..."

# 1. Lint staged
npx lint-staged

# 2. Check selectors
npx tsx scripts/check-selectors.ts

# 3. Quality Gates for Playwright tests
STAGED_SPECS=$(git diff --cached --name-only --diff-filter=ACM | grep -E "\.spec\.ts$" || true)

if [ -n "$STAGED_SPECS" ]; then
  # Check for focused tests
  if echo "$STAGED_SPECS" | xargs grep -nE "test\.only|describe\.only" > .focused_tests 2>&1; then
    echo ""
    echo "❌ Focused tests detected."
    cat .focused_tests
    echo ""
    echo "Remove:"
    echo "- test.only(...)"
    echo "- describe.only(...)"
    echo "before committing."
    rm .focused_tests
    exit 1
  fi
  rm -f .focused_tests

  # Check for skipped tests (warning)
  if echo "$STAGED_SPECS" | xargs grep -nE "test\.skip" > .skipped_tests 2>&1; then
    echo ""
    echo "⚠ Warning"
    echo "Skipped tests detected."
    echo "Review before committing:"
    cat .skipped_tests
    echo ""
  fi
  rm -f .skipped_tests
fi

# 4. Check for hard waits in all staged TS files
STAGED_TS=$(git diff --cached --name-only --diff-filter=ACM | grep -E "\.ts$" || true)
if [ -n "$STAGED_TS" ]; then
  if echo "$STAGED_TS" | xargs grep -nE "page\.waitForTimeout" > .hard_waits 2>&1; then
    echo ""
    echo "❌ Hard wait detected."
    cat .hard_waits
    echo ""
    echo "Use Playwright synchronization mechanisms instead of:"
    echo "page.waitForTimeout(...)"
    rm .hard_waits
    exit 1
  fi
  rm -f .hard_waits
fi
